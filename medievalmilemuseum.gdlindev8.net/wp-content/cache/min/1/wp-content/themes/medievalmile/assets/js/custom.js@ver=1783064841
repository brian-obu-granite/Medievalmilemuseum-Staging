// Scroll-direction-aware sticky header: hides on scroll down, reappears on
// scroll up (even mid-page), always visible at the very top. Stays visible
// while the mobile menu modal is open so it can't disappear mid-interaction.
// Leading semicolon guards against the previous statement (a bare function
// call with no trailing semicolon) being parsed as a call of this IIFE.
;(function () {
  var topBar = document.querySelector(".top-bar");
  var headerWrapper = document.querySelector(".header-wrapper");
  var siteHeader = document.getElementById("site-header");
  if (!headerWrapper) { return; }

  function setHeaderHeightVars() {
    var topBarHeight = topBar ? topBar.offsetHeight : 0;
    // .header-wrapper's own box has ~0 height (its child #site-header is
    // position:absolute per the theme's .header-footer-group rule, so it
    // doesn't contribute to the parent's height) - measure #site-header
    // directly so the hide transform can clear the real rendered height.
    var siteHeaderHeight = siteHeader ? siteHeader.offsetHeight : 0;
    document.documentElement.style.setProperty("--top-bar-height", topBarHeight + "px");
    document.documentElement.style.setProperty("--site-header-height", siteHeaderHeight + "px");
  }
  setHeaderHeightVars();
  window.addEventListener("resize", setHeaderHeightVars);

  var lastScrollY = window.scrollY;
  var ticking = false;
  var HIDE_CLASS = "header-hidden";

  function menuIsOpen() {
    return document.body.classList.contains("showing-menu-modal");
  }

  function onScroll() {
    var currentScrollY = window.scrollY;
    if (currentScrollY <= 0 || menuIsOpen()) {
      document.body.classList.remove(HIDE_CLASS);
    } else if (currentScrollY > lastScrollY) {
      document.body.classList.add(HIDE_CLASS);
    } else if (currentScrollY < lastScrollY) {
      document.body.classList.remove(HIDE_CLASS);
    }
    lastScrollY = currentScrollY;
    ticking = false;
  }

  window.addEventListener("scroll", function () {
    if (!ticking) {
      window.requestAnimationFrame(onScroll);
      ticking = true;
    }
  }, { passive: true });
})();